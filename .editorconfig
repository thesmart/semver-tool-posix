# Editor configuration, see http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
max_line_length= 99

[*.sh]
max_line_length = 88
indent_size = 2

[*.{html,htm}]
max_line_length= 99
indent_size = 2

[*.{css,scss}]
max_line_length= 99
indent_size = 2
quote_type = single

[*.{ts,tsx,js,jsx,cjs}]
max_line_length= 99
indent_size = 2
quote_type = single

[*.json]
indent_size = 2

[*.xml]
indent_size = 2

[*.svg]
indent_size = 2

[*.py]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 88

[*.go]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length= 99
